# Next.js 只读取 web/ 下的环境变量，不会自动加载仓库根目录 .env。
# 后端 API 默认只绑定 127.0.0.1，这里不要写成局域网 IP，否则代理会 502。
HYPEEDGE_BACKEND_URL=http://127.0.0.1:37001
NEXT_PUBLIC_HYPEEDGE_MARKET_WS_URL=ws://127.0.0.1:37001
# NEXT_PUBLIC_HYPEEDGE_MM_WS_URL=ws://127.0.0.1:37001

# Dashboard 鉴权默认关闭（内网单人）。需要 Basic Auth 时设为 on，并配置角色三元组。
# HYPEEDGE_DASHBOARD_AUTH=on
