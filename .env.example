# HypeEdge 环境变量示例
# 本地 dev/testnet 开发时复制为 .env：cp .env.example .env
# mainnet 密钥必须通过部署环境的 secret manager 注入，不要写入 .env
# 切勿将 .env 提交到版本控制

# ── 运行环境 ──────────────────────────────────────────────────
# 可选值：dev | testnet | mainnet
# 决定加载 configs/{env}.yaml 配置文件
HYPE_ENV=dev

# ── Hyperliquid 交易所连接 ────────────────────────────────────
# REST API 地址（主网）
HYPE_EXCHANGE__API_URL=https://api.hyperliquid.xyz
# WebSocket 地址（主网）
HYPE_EXCHANGE__WS_URL=wss://api.hyperliquid.xyz/ws

# Agent Wallet 凭证（只用 Agent/API Wallet；主钱包私钥禁止进入交易进程）
# 留空则仅采集行情，不启用交易
# 若填写凭证并启用交易，须将 HYPE_ENV 设为 mainnet，且 URL 必须为主网地址
HYPE_EXCHANGE__ACCOUNT_ADDRESS=
HYPE_EXCHANGE__AGENT_PRIVATE_KEY=

# 子账户名称（可选，不使用子账户时留空）
HYPE_EXCHANGE__SUB_ACCOUNT=

# ── 日志 ──────────────────────────────────────────────────────
# 日志级别：DEBUG | INFO | WARNING | ERROR
HYPE_LOG_LEVEL=DEBUG

# ── ClickHouse（行情时序数据）──────────────────────────────────
HYPE_CLICKHOUSE__HOST=localhost
HYPE_CLICKHOUSE__PORT=8123
HYPE_CLICKHOUSE__DATABASE=hypeedge

# ── Postgres（订单/持仓事务数据）────────────────────────────────
# 以下为 dev 便捷默认值；mainnet 启动会拒绝弱密码，须使用独立强凭证数据库
HYPE_POSTGRES__URL=postgresql+asyncpg://hypeedge:hypeedge@localhost:5432/hypeedge

# ── 后端 API 分级 Bearer Token ────────────────────────────────
# 每个 token 须唯一且至少 32 个随机字符；可用以下命令生成：
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
# 只读：查看行情、持仓、系统状态
HYPE_API__VIEWER_TOKEN=
# 操作员：策略启停、参数调整
HYPE_API__OPERATOR_TOKEN=
# 管理员：Kill Switch、高危操作
HYPE_API__ADMIN_TOKEN=

# ── Next.js 仪表盘（仅服务端读取，禁止 NEXT_PUBLIC_ 前缀）──────
# 后端内网地址
HYPEEDGE_BACKEND_URL=http://127.0.0.1:37001

# Viewer 角色：Dashboard Basic Auth + 对应后端 token（三者须同时配置）
HYPEEDGE_DASHBOARD_VIEWER_USERNAME=
HYPEEDGE_DASHBOARD_VIEWER_PASSWORD=
# 须与 HYPE_API__VIEWER_TOKEN 一致
HYPEEDGE_VIEWER_API_TOKEN=

# Operator 角色
HYPEEDGE_DASHBOARD_OPERATOR_USERNAME=
HYPEEDGE_DASHBOARD_OPERATOR_PASSWORD=
# 须与 HYPE_API__OPERATOR_TOKEN 一致
HYPEEDGE_OPERATOR_API_TOKEN=

# Admin 角色
HYPEEDGE_DASHBOARD_ADMIN_USERNAME=
HYPEEDGE_DASHBOARD_ADMIN_PASSWORD=
# 须与 HYPE_API__ADMIN_TOKEN 一致
HYPEEDGE_ADMIN_API_TOKEN=

# ── 前端公开行情 WebSocket（只读，不含交易凭证）────────────────
# 指向 HypeEdge 后端，不直连 Hyperliquid
NEXT_PUBLIC_HYPEEDGE_MARKET_WS_URL=ws://127.0.0.1:37001

# ── 旧版 Dashboard 凭证（兼容只读 viewer，新部署请用上方分级配置）──
HYPEEDGE_DASHBOARD_USERNAME=
HYPEEDGE_DASHBOARD_PASSWORD=
HYPEEDGE_API_TOKEN=
