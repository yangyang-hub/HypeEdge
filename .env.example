# HypeEdge 环境变量示例
# 本地开发时复制为 .env：cp .env.example .env
# mainnet 密钥必须通过部署环境的 secret manager 注入，不要写入 .env
# 切勿将 .env 提交到版本控制

# ── 运行环境 / Hyperliquid 网络 ───────────────────────────────
# 可选值：dev | testnet | mainnet
# - testnet / dev → 自动连接 Hyperliquid testnet（API + WS）
# - mainnet       → 自动连接 Hyperliquid mainnet（API + WS）
# 决定加载 configs/{env}.yaml；勿再手动设置 HYPE_EXCHANGE__API_URL / WS_URL
HYPE_ENV=testnet

# ── Hyperliquid 交易凭证 ──────────────────────────────────────
# Agent Wallet 凭证（只用 Agent/API Wallet；主钱包私钥禁止进入交易进程）
# 留空则仅采集行情，不启用交易
# 启用交易时：testnet/dev 用测试币；mainnet 用真实资金且须满足 mainnet 门禁
HYPE_EXCHANGE__ACCOUNT_ADDRESS=
HYPE_EXCHANGE__AGENT_PRIVATE_KEY=

# 子账户名称（可选，不使用子账户时留空）
HYPE_EXCHANGE__SUB_ACCOUNT=

# ── 日志 ──────────────────────────────────────────────────────
# 日志级别：DEBUG | INFO | WARNING | ERROR
HYPE_LOG_LEVEL=DEBUG

# ── ClickHouse（行情时序数据）──────────────────────────────────
HYPE_CLICKHOUSE__HOST=localhost
HYPE_CLICKHOUSE__PORT=8123
HYPE_CLICKHOUSE__DATABASE=hypeedge

# ── Postgres（订单/持仓事务数据）────────────────────────────────
# 以下为本地便捷默认值；mainnet 启动会拒绝弱密码，须使用独立强凭证数据库
HYPE_POSTGRES__URL=postgresql+asyncpg://hypeedge:hypeedge@localhost:5432/hypeedge

# ── 后端 API 监听（可选覆盖 YAML）────────────────────────────
# 纯内网 lab（dev/testnet）：configs 默认 host=0.0.0.0，可不配置任何 API token（无鉴权）。
# mainnet：必须配置 admin token；非回环监听时也必须有 token，禁止对公网开放无鉴权 API。
# HYPE_API__HOST=0.0.0.0

# ── 后端 API 分级 Bearer Token（可选；mainnet 必需）──────────
# 留空 = 纯内网无鉴权（仅 dev/testnet）。一旦配置任一 token，所有 /api 请求都须 Bearer。
# 每个 token 须唯一且至少 32 个随机字符：
#   python -c 'import secrets; print(secrets.token_urlsafe(48))'
# 只读：查看行情、持仓、系统状态
HYPE_API__VIEWER_TOKEN=
# 操作员：策略启停、参数调整
HYPE_API__OPERATOR_TOKEN=
# 管理员：Kill Switch、高危操作
HYPE_API__ADMIN_TOKEN=

# ── Next.js 仪表盘（服务端读取）────────────────────────────────
# 注意：Next.js 不会读取仓库根目录 .env，请同步配置到 web/.env.local
# 后端内网地址（同机代理请用 127.0.0.1，不要写局域网 IP）
HYPEEDGE_BACKEND_URL=http://127.0.0.1:37001

# 纯内网单人：上方 HYPE_API__*TOKEN 与下方 Dashboard 凭证全部留空；
# web/.env.local 不要设 HYPEEDGE_DASHBOARD_AUTH=on → 无登录、无角色限制。
# 若启用了 HYPE_API__*TOKEN，须在 web/.env.local 设 HYPEEDGE_DASHBOARD_AUTH=on
# 并为对应角色配置完整三元组，否则代理无法带 Bearer。

# Viewer 角色：Dashboard Basic Auth + 对应后端 token（三者须同时配置）
HYPEEDGE_DASHBOARD_VIEWER_USERNAME=
HYPEEDGE_DASHBOARD_VIEWER_PASSWORD=
# 须与 HYPE_API__VIEWER_TOKEN 一致
HYPEEDGE_VIEWER_API_TOKEN=

# Operator 角色
HYPEEDGE_DASHBOARD_OPERATOR_USERNAME=
HYPEEDGE_DASHBOARD_OPERATOR_PASSWORD=
# 须与 HYPE_API__OPERATOR_TOKEN 一致
HYPEEDGE_OPERATOR_API_TOKEN=

# Admin 角色
HYPEEDGE_DASHBOARD_ADMIN_USERNAME=
HYPEEDGE_DASHBOARD_ADMIN_PASSWORD=
# 须与 HYPE_API__ADMIN_TOKEN 一致
HYPEEDGE_ADMIN_API_TOKEN=

# ── 前端公开行情 WebSocket（只读，不含交易凭证）────────────────
# 指向 HypeEdge 后端，不直连 Hyperliquid。
# 本机页面可用 ws://127.0.0.1:37001；局域网页面用 ws://<主机局域网IP>:37001，
# 并确保该 Origin 已在 configs/*.yaml 的 api.cors_origins 中。
NEXT_PUBLIC_HYPEEDGE_MARKET_WS_URL=ws://127.0.0.1:37001

# ── 旧版 Dashboard 凭证（兼容只读 viewer，新部署请用上方分级配置）──
HYPEEDGE_DASHBOARD_USERNAME=
HYPEEDGE_DASHBOARD_PASSWORD=
HYPEEDGE_API_TOKEN=
